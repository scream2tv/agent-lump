# ─── Required ─────────────────────────────────────────────────────────────
BLOCKFROST_PROJECT_ID=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CARDANO_PAYMENT_ADDRESS=addr1qXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CARDANO_PRIVATE_KEY_PATH=/path/to/agent_payment.skey

# ─── DexHunter (optional — improves routing) ─────────────────────────────
# DEXHUNTER_PARTNER_ID=your_partner_id
# DEXHUNTER_API_KEY=your_dexhunter_api_key

# ─── CardexScan (optional — enables CardexScan aggregator) ───────────────
# CARDEXSCAN_API_KEY=your_cardexscan_api_key

# ─── Snek.fun (optional — defaults shown) ────────────────────────────────
# SNEKFUN_BUILDER_URL=https://builder.snek.fun
# SNEKFUN_ANALYTICS_URL=https://analytics.snek.fun

# ─── Minswap Aggregator (optional — defaults shown) ──────────────────────
# MINSWAP_AGGREGATOR_URL=https://aggr-monorepo-mainnet-prod.minswap.org/aggregator

# ─── Arbitrage Bot (optional — defaults shown) ───────────────────────────
# ARB_TRADE_AMOUNT_ADA=50
# ARB_MIN_PROFIT_ADA=2
# ARB_SCAN_INTERVAL_SEC=60
# ARB_UNIVERSE_REFRESH_MIN=10
# ARB_MAX_PRICE_IMPACT=2.0
# ARB_MAX_TRADE_ADA=100
# ARB_DRY_RUN=true
# ARB_MIN_LIQUIDITY_ADA=5000
# ARB_MIN_VOLUME_ADA=500

# ─── Bodega Market (optional — defaults shown) ──────────────────────────
# BODEGA_BASE_URL=https://v3.bodegamarket.io

# ─── Copy Trader (Snek.fun only — optional, defaults shown) ─────────────
# COPY_TRADER_TARGET=addr1q93u89sdcn4gynddd3y20jmssnpecv2xfu8qht232rymlvs9aghu02lfwfwuht9q7ttx9u7qhxxqaur7d4fwjm0kvcuqv99rn4
# COPY_TRADER_POLL_SEC=30
# COPY_TRADER_SLIPPAGE=15
# COPY_TRADER_DRY_RUN=false
#
# Buy sizing: fixed | pct-target | pct-wallet
# COPY_TRADER_BUY_MODE=fixed
# COPY_TRADER_BUY_VALUE=10       # ADA if fixed; percent otherwise
# COPY_TRADER_MIN_BUY_ADA=1
# COPY_TRADER_MAX_BUY_ADA=100
#
# Sell sizing: all | pct-holding
# COPY_TRADER_SELL_MODE=all
# COPY_TRADER_SELL_VALUE=100     # percent (ignored if mode=all)

# ─── Ascend Prediction Market (optional — Midnight testnet) ──────────────
# ASCEND_API_URL=https://masumi-ascend-preview-mc952.ondigitalocean.app
# ASCEND_API_KEY=your_ascend_api_key_here

# ─── Midnight Network ────────────────────────────────────────────────────
# Midnight configuration lives in midnight-agent/.env
# See midnight-agent/README.md for setup instructions

# ─── Midnight MCP (optional — improves rate limits) ─────────────────────
# GITHUB_TOKEN=ghp_your_github_token_here
