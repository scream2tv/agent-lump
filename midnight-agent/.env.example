# ─── Network ──────────────────────────────────────────────────────────────
# mainnet | preprod | preview
MIDNIGHT_NETWORK=mainnet

# ─── RPC (Substrate JSON-RPC) ────────────────────────────────────────────
MIDNIGHT_RPC_URL=https://rpc.mainnet.midnight.network/
MIDNIGHT_RPC_WSS_URL=wss://rpc.mainnet.midnight.network

# ─── Indexer (GraphQL) ───────────────────────────────────────────────────
MIDNIGHT_INDEXER_URL=https://indexer.mainnet.midnight.network/api/v4/graphql
MIDNIGHT_INDEXER_WS_URL=wss://indexer.mainnet.midnight.network/api/v4/graphql/ws

# ─── Prover ──────────────────────────────────────────────────────────────
# Remote proof server (no local Docker needed for mainnet)
# MIDNIGHT_PROVER_URL=http://localhost:6300

# ─── Explorer ────────────────────────────────────────────────────────────
# MIDNIGHT_EXPLORER_URL=https://explorer.mainnet.midnight.network

# ─── Wallet seed (hex-encoded, 32 bytes) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MIDNIGHT_WALLET_SEED=
